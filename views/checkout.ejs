<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Homemade+Apple&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* Checkout specific inline overrides for speed, though most should be in style.css */
    .checkout-section { padding-top: 40px; padding-bottom: 80px; }
    .checkout-layout { display: grid; grid-template-columns: 1.5fr 1fr; gap: 60px; align-items: start; }
    
    .checkout-notices { font-size: 13px; color: var(--color-text-light); margin-bottom: 32px; }
    .checkout-notices a { color: var(--color-dark); font-weight: 600; text-decoration: underline; margin-left: 4px; }
    .checkout-notices p { margin-bottom: 8px; }

    .checkout-heading { font-size: 18px; font-weight: 700; margin-bottom: 24px; color: var(--color-dark); }
    
    .form-row { display: flex; gap: 20px; margin-bottom: 20px; }
    .form-group { flex: 1; display: flex; flex-direction: column; }
    .form-group.full-width { width: 100%; flex: none; }
    
    .form-label { font-size: 12px; margin-bottom: 8px; color: var(--color-text); }
    .form-label.required::after { content: ' *'; color: red; }
    
    .form-input, .form-select, .form-textarea {
      border: 1px solid var(--color-gray-light);
      padding: 12px 16px;
      font-size: 13px;
      font-family: var(--font-body);
      border-radius: 2px;
      outline: none;
      transition: border-color var(--transition);
      background: var(--color-white);
    }
    .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--color-dark); }
    .form-textarea { resize: vertical; min-height: 80px; }
    
    .form-checkbox-group { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; font-size: 13px; color: var(--color-text); cursor: pointer; }
    .form-checkbox-group input { cursor: pointer; }

    /* Order Summary Widget */
    .order-summary-box { border: 2px solid var(--color-gray-light); padding: 32px; border-radius: 2px; }
    .order-summary-heading { font-size: 14px; font-weight: 700; margin-bottom: 24px; letter-spacing: 0.05em; text-transform: uppercase; }
    
    .order-table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
    .order-table th { text-align: left; font-size: 11px; font-weight: 700; border-bottom: 1px solid var(--color-gray-light); padding-bottom: 12px; }
    .order-table .th-product { width: 70%; }
    
    .order-item-row { border-bottom: 1px solid var(--color-gray-light); }
    .order-item-row td { padding: 16px 0; font-size: 13px; vertical-align: middle; }
    .order-item-product { display: flex; align-items: center; gap: 12px; }
    .order-item-img { width: 50px; height: 50px; object-fit: cover; background: var(--color-light); border: 1px solid var(--color-gray-light); }
    .order-item-name { font-weight: 500; color: var(--color-dark); line-height: 1.4; }
    .order-item-qty { font-weight: 600; color: var(--color-text-light); }
    .order-item-total { text-align: right; font-weight: 600; color: var(--color-dark); }

    .order-totals-row { display: flex; justify-content: space-between; font-size: 13px; font-weight: 600; padding: 16px 0; border-bottom: 1px solid var(--color-gray-light); color: var(--color-text); }
    .order-total-final { display: flex; justify-content: space-between; font-size: 16px; font-weight: 700; padding: 24px 0; color: var(--color-dark); }
    
    .payment-methods { margin-bottom: 24px; }
    .payment-method { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 12px; }
    .payment-method input { margin-top: 4px; }
    .payment-method-details { display: flex; flex-direction: column; }
    .payment-logo { height: 24px; object-fit: contain; margin-bottom: 8px; }
    .payment-desc { font-size: 11px; color: var(--color-text-light); line-height: 1.6; }
    
    .privacy-notice { font-size: 11px; color: var(--color-text-light); line-height: 1.6; padding: 16px 0; margin-bottom: 24px; border-top: 1px solid var(--color-gray-light); }
    .privacy-notice a { color: var(--color-dark); text-decoration: underline; }
    
    .btn-place-order { background: var(--color-dark); color: var(--color-white); width: 100%; border: none; padding: 18px; font-size: 13px; font-weight: 700; letter-spacing: 0.05em; cursor: pointer; transition: all var(--transition); border-radius: 2px; }
    .btn-place-order:hover { background: #000; }
    .btn-place-order:disabled { opacity: 0.7; cursor: not-allowed; }

    @media (max-width: 768px) {
      .checkout-layout { grid-template-columns: 1fr; gap: 40px; }
      .form-row { flex-direction: column; gap: 0; }
    }
  </style>
</head>
<body>
  <%- include('partials/header') %>

  <section class="page-header" style="border-bottom: none; padding-bottom: 0;">
    <div class="container" style="text-align: center;">
      <div class="cart-steps" style="font-size: 16px; font-weight: 700; color: #333;">
        <span style="color: #ccc;">Shopping Cart</span> <span style="margin: 0 10px; color: #ccc;">&gt;</span>
        <span>Checkout</span> <span style="margin: 0 10px; color: #ccc;">&gt;</span>
        <span style="color: #ccc;">Order Complete</span>
      </div>
    </div>
  </section>

  <section class="section checkout-section">
    <div class="container">
      <div class="checkout-layout">
        
        <!-- Left: Form -->
        <div class="checkout-form-column">
          <div class="checkout-notices">
            <p>Returning customer? <a href="#">login</a></p>
            <p>Have a coupon? <a href="#">ENTER YOUR CODE</a></p>
          </div>

          <h2 class="checkout-heading">Contact Information</h2>
          <form id="checkout-form">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label required">First Name</label>
                <input type="text" class="form-input" name="firstName" required>
              </div>
              <div class="form-group">
                <label class="form-label">Last Name (optional)</label>
                <input type="text" class="form-input" name="lastName">
              </div>
            </div>

            <div class="form-group full-width" style="margin-bottom: 20px;">
              <label class="form-label required">Country</label>
              <div style="font-size: 13px; font-weight: 600; padding: 12px 16px; border: 1px solid var(--color-gray-light); background: var(--color-light);">Indonesia</div>
            </div>

            <div class="form-group full-width" style="margin-bottom: 20px;">
              <label class="form-label required">Address</label>
              <input type="text" class="form-input" placeholder="Street, House Number, Apartment" required>
            </div>

            <div class="form-group full-width" style="margin-bottom: 20px;">
              <label class="form-label required">Province</label>
              <select class="form-select" required>
                <option value="">Select an option...</option>
                <option value="DKI Jakarta">DKI Jakarta</option>
                <option value="Jawa Barat">Jawa Barat</option>
                <option value="Jawa Tengah">Jawa Tengah</option>
                <option value="Jawa Timur">Jawa Timur</option>
                <option value="Banten">Banten</option>
                <option value="Bali">Bali</option>
              </select>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label required">City</label>
                <select class="form-select" required>
                  <option value="">Select city...</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label required">District</label>
                <select class="form-select" required>
                  <option value="">Select district...</option>
                </select>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Kelurahan (optional)</label>
                <input type="text" class="form-input">
              </div>
              <div class="form-group">
                <label class="form-label">Zipcode (optional)</label>
                <input type="text" class="form-input">
              </div>
            </div>

            <div class="form-group full-width" style="margin-bottom: 20px;">
              <label class="form-label required">Phone</label>
              <input type="tel" class="form-input" name="phone" required>
            </div>

            <div class="form-group full-width" style="margin-bottom: 24px;">
              <label class="form-label required">Email address</label>
              <input type="email" class="form-input" name="email" required>
            </div>

            <label class="form-checkbox-group">
              <input type="checkbox"> Create an account?
            </label>
            <label class="form-checkbox-group" style="margin-bottom: 24px;">
              <input type="checkbox"> Ship to a different address?
            </label>

            <div class="form-group full-width" style="margin-bottom: 20px;">
              <label class="form-label">Order notes (optional)</label>
              <textarea class="form-textarea" placeholder="Notes about your order, e.g. special notes for delivery."></textarea>
            </div>
          </form>
        </div>

        <!-- Right: Order Summary -->
        <div class="checkout-summary-column">
          <div class="order-summary-box">
            <h2 class="order-summary-heading">YOUR ORDER</h2>
            
            <table class="order-table">
              <thead>
                <tr>
                  <th class="th-product">PRODUCT</th>
                  <th>SUBTOTAL</th>
                </tr>
              </thead>
              <tbody id="checkout-items">
                <tr><td colspan="2" style="text-align:center; padding: 20px;">Loading order details...</td></tr>
              </tbody>
            </table>

            <div class="order-totals-row">
              <span>Subtotal</span>
              <span id="checkout-subtotal">Rp0</span>
            </div>
            <div class="order-totals-row">
              <span style="font-weight: 400;">Biaya Layanan</span>
              <span style="font-weight: 400;">Rp2.500</span>
            </div>
            <div class="order-total-final">
              <span>Total</span>
              <span id="checkout-total">Rp0</span>
            </div>

            <div class="payment-methods">
              <label class="payment-method">
                <input type="radio" name="payment_method" checked>
                <div class="payment-method-details">
                  <strong style="font-size: 13px; margin-bottom: 8px;">iPaymu</strong>
                  <div class="payment-desc">
                    Pembayaran melalui virtual account (BCA, Mandiri, BNI, BRI, Permata, Cimb Niaga, Danamon, dsb), QRIS, Alfamart / Indomaret, Credit Card, dan lainnya.
                  </div>
                </div>
              </label>
            </div>

            <div class="privacy-notice">
              Your personal data will be used to process your order, support your experience throughout this website, and for other purposes described in our <a href="#">privacy policy</a>.
            </div>

            <button type="submit" form="checkout-form" class="btn-place-order" id="place-order-btn">PLACE ORDER</button>
          </div>
        </div>

      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <%- include('partials/whatsapp') %>
  <script src="/js/main.js"></script>
  
  <script>
    document.addEventListener('DOMContentLoaded', async () => {
      const cartId = localStorage.getItem('shopify_cart_id');
      const itemsEl = document.getElementById('checkout-items');
      const subtotalEl = document.getElementById('checkout-subtotal');
      const totalEl = document.getElementById('checkout-total');
      const placeOrderBtn = document.getElementById('place-order-btn');
      const fee = 2500;

      if (!cartId) {
        itemsEl.innerHTML = '<tr><td colspan="2" style="text-align:center; padding: 20px;">Your cart is empty</td></tr>';
        placeOrderBtn.disabled = true;
        return;
      }

      try {
        const response = await fetch(`/api/cart/${encodeURIComponent(cartId)}`);
        const data = await response.json();
        
        if (!data || !data.cart) throw new Error('Cart not found');
        const cart = data.cart;
        
        if (cart.lines.edges.length === 0) {
          itemsEl.innerHTML = '<tr><td colspan="2" style="text-align:center; padding: 20px;">Your cart is empty</td></tr>';
          placeOrderBtn.disabled = true;
          return;
        }

        let itemsHtml = '';
        cart.lines.edges.forEach(({ node: line }) => {
          const product = line.merchandise.product;
          const variant = line.merchandise;
          const price = parseFloat(variant.price.amount);
          const total = price * line.quantity;
          const title = product ? product.title : variant.title;
          const imageUrl = (product && product.images && product.images.edges.length > 0) 
              ? product.images.edges[0].node.url : '/assets/placeholder.svg';

          itemsHtml += `
            <tr class="order-item-row">
              <td>
                <div class="order-item-product">
                  <img src="${imageUrl}" alt="${title}" class="order-item-img">
                  <div>
                    <div class="order-item-name">${title}</div>
                    <div class="order-item-qty">x ${line.quantity}</div>
                  </div>
                </div>
              </td>
              <td class="order-item-total">${formatPrice(total)}</td>
            </tr>
          `;
        });

        itemsEl.innerHTML = itemsHtml;
        
        const subTotalCost = parseFloat(cart.cost.subtotalAmount.amount);
        const totalCost = subTotalCost + fee;
        
        subtotalEl.textContent = formatPrice(subTotalCost);
        totalEl.textContent = formatPrice(totalCost);

      } catch (error) {
        console.error('Failed to load checkout details:', error);
        itemsEl.innerHTML = '<tr><td colspan="2" style="text-align:center; color:red; padding: 20px;">Failed to load order data.</td></tr>';
        placeOrderBtn.disabled = true;
      }

      // Handle Place Order logic
      const checkoutForm = document.getElementById('checkout-form');
      checkoutForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Disable button to prevent double submission
        placeOrderBtn.disabled = true;
        placeOrderBtn.textContent = 'MENGHUBUNGKAN KE IPAYMU...';
        
        try {
          const cartId = localStorage.getItem('shopify_cart_id');
          const formData = new FormData(checkoutForm);
          const customer = {
             firstName: formData.get('firstName'),
             lastName: formData.get('lastName'),
             email: formData.get('email'),
             phone: formData.get('phone')
          };
          
          const res = await fetch('/api/checkout/ipaymu', {
             method: 'POST',
             headers: { 'Content-Type': 'application/json' },
             body: JSON.stringify({ cartId, customer })
          });
          
          const result = await res.json();
          if (result.success && result.paymentUrl) {
             // Redirect user to iPaymu
             window.location.href = result.paymentUrl;
          } else {
             throw new Error(result.error || 'Failed to initialize payment');
          }
        } catch (error) {
          alert('Mohon lengkapi konfigurasi iPaymu (VA & API Key) pada .env untuk melanjutkan. Error: ' + error.message);
          placeOrderBtn.disabled = false;
          placeOrderBtn.textContent = 'PLACE ORDER';
        }
      });
    });

    function formatPrice(price) {
      return 'Rp' + Math.round(price).toLocaleString('id-ID');
    }
  </script>
</body>
</html>
