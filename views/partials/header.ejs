<!-- Main Header -->
<header class="main-header" id="main-header">
  <div class="header-inner">
    <div class="header-logo">
      <a href="/">
        <span class="logo-text">Plan Your Skin.</span>
      </a>
    </div>
    <div class="header-actions">
      <% if (typeof customer !== 'undefined' && customer) { %>
        <a href="#" class="header-icon" id="account-logout" aria-label="Log Out" title="Logged in as <%= customer.firstName %>, Click to Log Out">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </a>
      <% } else { %>
        <a href="#" class="header-icon" id="account-icon" aria-label="My Account">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
      <% } %>
      <div class="cart-container has-cart-dropdown">
        <a href="/cart" class="header-icon cart-icon" id="cart-icon" aria-label="Cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span class="cart-count">0</span>
        </a>
        <div class="cart-dropdown" id="cart-hover-dropdown">
          <div class="cart-dropdown-header">
            <span class="cart-dropdown-item-count" id="cart-hover-count">0 ITEM</span>
            <a href="/cart" class="cart-dropdown-view-link">VIEW CART</a>
          </div>
          <div class="cart-dropdown-items" id="cart-hover-items">
            <div class="cart-dropdown-empty">Your cart is currently empty.</div>
          </div>
          <div class="cart-dropdown-footer" id="cart-hover-footer" style="display: none;">
            <div class="cart-dropdown-subtotal">
              <span>SUBTOTAL:</span>
              <span id="cart-hover-subtotal">Rp0</span>
            </div>
            <a href="#" class="btn btn-primary" id="cart-hover-checkout" style="width: 100%; text-align: center; border-radius: 2px;">CHECKOUT</a>
          </div>
        </div>
      </div>
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
